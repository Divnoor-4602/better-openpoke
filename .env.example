# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: shared password gating the demo. Every tester uses this same
# password; each tester picks their own handle (becomes their workspace_id).
DEMO_PASSWORD=change_me

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Google (GOOGLESUPER) auth config ID
# Get these from https://composio.dev/ — the auth config must include
# Gmail + Calendar + Meet scopes (i.e. the GOOGLESUPER toolkit).
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GOOGLE_AUTH_CONFIG_ID=your_google_auth_config_id_here

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001
# PORT takes precedence over OPENPOKE_PORT (Railway/Heroku inject it automatically).
# PORT=8001

# Optional: Persistent data dir for SQLite + JSON state. Defaults to ./server/data
# locally. In Railway, mount a Volume at /data and set this to the mount path so
# state survives redeploys.
# OPENPOKE_DATA_DIR=/data

# Optional: web app → API base URL (read by Vite at build time as VITE_API_URL).
# Defaults to http://localhost:8001 if unset.
# VITE_API_URL=http://localhost:8001

# Optional: Pinecone hybrid memory search
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_HOST=https://your-index-host.pinecone.io
# MEMORY_SEARCH_BACKEND=pinecone_hybrid

# Optional: Async memory indexing worker
# SQLite memory_index_queue is the durable outbox.
# MEMORY_INDEX_WORKERS=2
# MEMORY_INDEX_BATCH_SIZE=50
# MEMORY_INDEX_MAX_ATTEMPTS=5
# MEMORY_INDEX_POLL_INTERVAL_SECONDS=2
# MEMORY_DEBUG_LOG_CONTENT=0

# Optional: CORS configuration
# When the frontend is hosted on a different origin and auth is enabled
# (the demo case), set this to an explicit comma-separated list of allowed
# origins. A wildcard (*) is incompatible with the Authorization header
# the browser sends after `credentials: 'include'`.
# OPENPOKE_CORS_ALLOW_ORIGINS=http://localhost:5173

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs
