# Clerk
# Clerk publishable key (required in browser)
VITE_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (required on server by @clerk/tanstack-react-start)
CLERK_SECRET_KEY=
# Clerk JWT issuer domain for Convex auth.config.ts, e.g. https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Convex
# Convex deployment name
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=
