# Convex local/dev settings
CONVEX_DEPLOYMENT=dev:<deployment-name>
CONVEX_URL=https://<deployment-name>.convex.cloud
CONVEX_SITE_URL=https://<deployment-name>.convex.site

# Auth / webhooks
CLERK_JWT_ISSUER_DOMAIN=https://<your-clerk-domain>
CLERK_WEBHOOK_SECRET=<your-clerk-webhook-secret>

# Convex Agent Component / Vercel AI SDK OpenAI provider
OPENAI_API_KEY=<your-openai-api-key>
LEGAL_POKE_AGENT_MODEL=gpt-5.5

# Assembly api key
ASSEMBLY_API_KEY= <assembly_api_key>

# zelda
ZELDA_JWT_SECRET=

# meeting baas
MEETINGBAAS_API_KEY
