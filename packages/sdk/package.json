{
  "name": "@openpoke/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated": {
      "types": "./src/generated/index.ts",
      "default": "./src/generated/index.ts"
    },
    "./react-query": {
      "types": "./src/react-query.ts",
      "default": "./src/react-query.ts"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "default": "./src/zod.ts"
    }
  },
  "scripts": {
    "generate": "/Users/divnoor/anaconda3/envs/better-openpoke/bin/python ../../server/scripts/export_openapi.py --output ../../server/generated/openapi.json && openapi-ts",
    "build": "tsc --noEmit",
    "check": "bun run generate && git diff --exit-code -- src/generated && bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.10"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.1",
    "@tanstack/react-query": "^5.100.10",
    "typescript": "^6.0.2"
  }
}
